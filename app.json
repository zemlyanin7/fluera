      "bundleIdentifier": "com.fluera.app"
    },
    "android": {
      "package": "com.fluera.app",
      "adaptiveIcon": {
        "backgroundColor": "#6c63ff"
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
