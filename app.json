{
  "expo": {
    "name": "Fluera",
    "slug": "fluera",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "fluera",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
